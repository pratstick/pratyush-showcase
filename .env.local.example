# EmailJS credentials — copy this file to .env.local and fill in your values.
# Sign up at https://www.emailjs.com and create a service + email template.
#
# Template variables expected by the template:
#   {{from_name}}    — sender's name
#   {{from_email}}   — sender's email address
#   {{message}}      — message body
#   {{to_name}}      — recipient name (your name)

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
